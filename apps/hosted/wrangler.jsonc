{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fizzy-mcp-hosted",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-17",
  "compatibility_flags": ["nodejs_compat"],

  // Enable observability for monitoring
  "observability": {
    "enabled": true,
  },

  // Environment variables
  "vars": {
    "ENVIRONMENT": "production",
  },

  // Durable Objects for vibe coding
  "durable_objects": {
    "bindings": [
      { "name": "SESSION_REGISTRY", "class_name": "SessionRegistry" },
      { "name": "WORK_QUEUE", "class_name": "WorkQueue" },
      { "name": "CARD_LOCK", "class_name": "CardLock" },
    ],
  },

  // Durable Object migrations
  "migrations": [{ "tag": "v1", "new_classes": ["SessionRegistry", "WorkQueue", "CardLock"] }],

  // Custom domain configuration - MCP proxy endpoint
  "routes": [
    {
      "pattern": "mcp.fizzy.yogan.dev",
      "custom_domain": true,
    },
  ],
}
