{
  "name": "@fizzy-mcp/server",
  "version": "0.1.0",
  "description": "MCP server for integrating AI agents with Fizzy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fizzy-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@fizzy-mcp/client": "workspace:*",
    "@fizzy-mcp/shared": "workspace:*",
    "@fizzy-mcp/tools": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "commander": "^12.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "fizzy",
    "basecamp",
    "ai",
    "claude",
    "llm"
  ],
  "license": "MIT"
}
